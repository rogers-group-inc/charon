# Charon configuration — copy to .env and fill in. NEVER commit .env (the repo
# is public; .gitignore blocks it). First-run setup generates .env for you with
# fresh secrets; this file documents every knob.

# ─── Core ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by the app (Prisma).
DATABASE_URL=postgresql://charon:CHANGE_ME@localhost:5432/charon
# Optional: a session-level direct connection for pg-boss / pg_dump when a
# pooler (PgBouncer) fronts DATABASE_URL. Leave unset for a direct Postgres.
# CHARON_DB_DIRECT_URL=postgresql://charon:CHANGE_ME@localhost:5432/charon

# Long random value — signs session cookies. Required in production.
SESSION_SECRET=CHANGE_ME_long_random_value

# 32-byte key (base64 or hex) that encrypts every at-rest secret (AES-256-GCM).
# Required in production. Back this up to Key Vault — losing it makes stored
# integration credentials unrecoverable. Generate: openssl rand -base64 32
CHARON_DATA_KEY=CHANGE_ME_base64_32_bytes

# Bearer tokens gating /health and /metrics (optional; open when unset).
# HEALTH_TOKEN=
# METRICS_TOKEN=

NODE_ENV=production
# LOG_LEVEL=info
# PORT=3000
# CHARON_BIND=127.0.0.1            # app listens localhost-only behind nginx

# ─── Multi-process role ─────────────────────────────────────────────────────
# Unset = "all" (single process; dev default). Production splits roles:
#   web | endpoint | enforcer | worker | migrate
# CHARON_ROLE=web
# CHARON_METRICS_PORT=9109         # enforcer/worker expose /metrics here
# CHARON_METRICS_BIND=127.0.0.1
# DATABASE_POOL_SIZE=25
# CHARON_PGBOSS_POOL_SIZE=10

# ─── High availability (leader election) ────────────────────────────────────
# Both nodes contend on the same advisory lock; only the leader runs schedulers
# and enforcement scheduling. Override only for test isolation.
# CHARON_LEADER_LOCK_KEY=728405146
# CHARON_LEADER_RETRY_MS=10000
# CHARON_PUBLIC_URL=https://charon.example.com   # surfaced to the GSLB via /health

# ─── In-app updater ─────────────────────────────────────────────────────────
# Override the git remote the updater pulls from (defaults to origin).
# CHARON_UPDATE_REPO=https://github.com/rogers-group-inc/charon.git
