{
  "name": "charon",
  "version": "0.1.0",
  "description": "Charon — Zero Trust Network Access (ZTNA) platform: identity + posture → dynamic FortiGate tags & policies",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "prisma generate && (git config core.hooksPath .githooks || true)",
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "build": "tsc && node scripts/copy-build-assets.mjs",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node --env-file=.env --import tsx/esm prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "check:docs": "node scripts/check-docs.mjs"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@node-saml/node-saml": "^5.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/ws": "^8.18.1",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.0.0",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "ldapts": "^8.1.7",
    "multer": "^2.1.1",
    "openid-client": "^6.1.7",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0",
    "pg-boss": "^12.18.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "undici": "^8.7.0",
    "ws": "^8.20.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "tsx": "^4.15.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
